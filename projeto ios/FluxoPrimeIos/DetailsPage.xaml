<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:FluxoPrimeMaui.Converters"
             x:Class="FluxoPrimeMaui.DetailsPage"
             x:Name="RootPage"
             Title="{Binding Stream.Name}"
             BackgroundColor="#050912">

    <ContentPage.Resources>
        <conv:ImageUrlConverter x:Key="ImageUrlConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" Padding="14,12">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="0,0,0,10">
            <Button Text="Voltar"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="#121A2B"
                    TextColor="#B9C8E8"
                    Padding="12,8" />
            <Label Grid.Column="1"
                   Text="{Binding Stream.Name}"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   LineBreakMode="TailTruncation"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">
                <Grid ColumnDefinitions="130,*" ColumnSpacing="14">
                    <Border BackgroundColor="#07101D"
                            Stroke="#1F3356"
                            StrokeThickness="1"
                            HeightRequest="190">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image Source="{Binding CoverImage, Converter={StaticResource ImageUrlConverter}}"
                               Aspect="AspectFill" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="{Binding Stream.Name}"
                               TextColor="White"
                               FontSize="24"
                               FontAttributes="Bold"
                               LineBreakMode="WordWrap" />
                        <Label Text="{Binding DetailsText}"
                               TextColor="#B9C8E8"
                               FontSize="13"
                               LineBreakMode="WordWrap"
                               MaxLines="7" />
                    </VerticalStackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Text="Assistir"
                            Command="{Binding PlayCommand}"
                            IsVisible="{Binding IsPlayable}"
                            BackgroundColor="#FFD34D"
                            TextColor="#101420"
                            FontAttributes="Bold" />
                    <Button Grid.Column="1"
                            Text="{Binding FavoriteButtonText}"
                            Command="{Binding ToggleFavoriteCommand}"
                            BackgroundColor="#13223A"
                            TextColor="White"
                            FontAttributes="Bold" />
                </Grid>

                <VerticalStackLayout IsVisible="{Binding HasPlot}"
                                     Spacing="6">
                    <Label Text="Sinopse"
                           TextColor="#FFD34D"
                           FontSize="13"
                           FontAttributes="Bold" />
                    <Label Text="{Binding PlotText}"
                           TextColor="#D6E2FF"
                           FontSize="13"
                           LineBreakMode="WordWrap"
                           MaxLines="7" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding HasRecommendations}"
                                     Spacing="8">
                    <Label Text="Similares"
                           TextColor="#FFD34D"
                           FontSize="13"
                           FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding RecommendedStreams}"
                                    ItemsLayout="HorizontalList"
                                    HeightRequest="190"
                                    SelectionMode="None"
                                    ItemSizingStrategy="MeasureFirstItem">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout WidthRequest="104"
                                                     Margin="0,0,10,0"
                                                     Spacing="5">
                                    <Border BackgroundColor="#07101D"
                                            Stroke="#1F3356"
                                            StrokeThickness="1"
                                            HeightRequest="142">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Image Source="{Binding Icon, Converter={StaticResource ImageUrlConverter}}"
                                               Aspect="AspectFill" />
                                    </Border>
                                    <Label Text="{Binding Name}"
                                           TextColor="White"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.SelectRecommendationCommand, Source={x:Reference RootPage}}"
                                                              CommandParameter="{Binding .}" />
                                    </VerticalStackLayout.GestureRecognizers>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#FFD34D"
                                   HorizontalOptions="Center" />

                <VerticalStackLayout IsVisible="{Binding IsSeries}" Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Text="Episodios"
                               TextColor="White"
                               FontSize="20"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Border Grid.Column="1"
                                BackgroundColor="#101A2D"
                                Stroke="#1F3356"
                                Padding="10,2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Picker ItemsSource="{Binding SeasonOptions}"
                                    SelectedItem="{Binding SelectedSeason}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    TextColor="White"
                                    TitleColor="#8FA6CC"
                                    BackgroundColor="Transparent"
                                    WidthRequest="150"
                                    Title="Temporada" />
                        </Border>
                    </Grid>

                    <Border IsVisible="{Binding HasContinueEpisode}"
                            Padding="12"
                            BackgroundColor="#121A2B"
                            Stroke="#FFD34D"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Continuar"
                                       TextColor="#FFD34D"
                                       FontAttributes="Bold"
                                       FontSize="12" />
                                <Label Text="{Binding ContinueEpisode.DisplayTitle}"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Play"
                                    Command="{Binding PlayEpisodeCommand}"
                                    CommandParameter="{Binding ContinueEpisode}"
                                    BackgroundColor="#FFD34D"
                                    TextColor="#101420"
                                    Padding="14,7" />
                        </Grid>
                    </Border>

                    <CollectionView ItemsSource="{Binding SelectedEpisodes}"
                                    SelectionMode="None"
                                    HeightRequest="390">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="3"
                                             HorizontalItemSpacing="8"
                                             VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8"
                                        HeightRequest="92"
                                        BackgroundColor="#0B1220"
                                        Stroke="#1C3154"
                                        StrokeThickness="1">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding EpisodeCode}"
                                                   TextColor="White"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding WatchStatus}"
                                                   TextColor="#FFD34D"
                                                   FontSize="9"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <Label Grid.Row="1"
                                               Text="{Binding CardTitle}"
                                               TextColor="#B9C8E8"
                                               FontSize="11"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />

                                        <BoxView Grid.Row="2"
                                                 HeightRequest="3"
                                                 CornerRadius="2"
                                                 BackgroundColor="#263650"
                                                 HorizontalOptions="Fill" />
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.PlayEpisodeCommand, Source={x:Reference RootPage}}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
