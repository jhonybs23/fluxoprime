<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FluxoPrimeMaui.LoginPage"
             Title="FluxoPrime TV"
             BackgroundColor="#050912">

    <Grid Padding="24" RowDefinitions="*,Auto,*">
        <VerticalStackLayout Grid.Row="1" Spacing="18">
            <Border WidthRequest="58"
                    HeightRequest="58"
                    HorizontalOptions="Center"
                    BackgroundColor="#123B69"
                    Stroke="#245B94"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label Text="TV"
                       TextColor="#8DD7FF"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <VerticalStackLayout Spacing="4">
                <Label Text="FluxoPrime TV"
                       TextColor="White"
                       FontSize="30"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <Label Text="IPTV Player"
                       TextColor="#AFC4E8"
                       FontSize="15"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border BackgroundColor="#0B1220"
                    Stroke="#1F3356"
                    StrokeThickness="1"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Border BackgroundColor="#111827"
                            Stroke="#263A61"
                            StrokeThickness="1"
                            Padding="10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Text="{Binding DnsStatusMessage}"
                                   TextColor="#AFC4E8"
                                   FontSize="12"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation" />
                            <Button Grid.Column="1"
                                    Text="Atualizar"
                                    Command="{Binding RefreshDnsCommand}"
                                    BackgroundColor="#1F3356"
                                    TextColor="White"
                                    FontSize="12"
                                    Padding="10,6" />
                        </Grid>
                    </Border>

                    <Entry Placeholder="Usuario"
                           Text="{Binding Username}"
                           Keyboard="Numeric"
                           BackgroundColor="#111827"
                           TextColor="White"
                           PlaceholderColor="#7E8AA8" />

                    <Entry Placeholder="Senha"
                           IsPassword="True"
                           Text="{Binding Password}"
                           BackgroundColor="#111827"
                           TextColor="White"
                           PlaceholderColor="#7E8AA8" />

                    <Button Text="Entrar"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="#FFD34D"
                            TextColor="#101420"
                            FontAttributes="Bold" />

                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       Color="#FFD34D" />

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#FF8A8A"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
